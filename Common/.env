# .env -- Shared Local LLM pipeline configuration
#
# Location: nmonLocalLLM/Common/.env
# Consumed by:
#   - LocalLLMCoding/Arch_Coding_Pipeline.ps1  (when -Local)
#   - LocalLLMCoding/run_aider.py                (when --local)
#   - LocalLLMDebug/*_local.ps1                  (analysis scripts)

# ── Ollama server endpoint ──
# One-line override: uncomment LLM_ENDPOINT to use a full URL.
# Otherwise LLM_HOST + LLM_PORT are composed into http://HOST:PORT.
#LLM_ENDPOINT=http://192.168.1.126:11434
LLM_HOST=192.168.1.126
LLM_PORT=11434

# ── Models ──
#
# LLM_DEFAULT_MODEL is the universal fallback. Every role-specific key
# below falls back to it when blank or unset — so changing the coder
# model system-wide = edit LLM_DEFAULT_MODEL and nothing else.
#
# Role overrides only need to be set when a role uses a DIFFERENT model
# from the default (e.g., a reasoning model for planning).
#
# Resolution chain (both Python cfg.resolve_model and PowerShell Get-LLMModel):
#   role-specific key  ->  LLM_DEFAULT_MODEL  ->  hardcoded fallback

LLM_DEFAULT_MODEL=qwen3-coder:30b
#LLM_DEFAULT_MODEL=qwen3.6:35b-a3b

# Planning stages (coding 0, 1, 2a, 2b, 3a, 3b when --local). Benefits from
# a reasoning model for long-context structured output. Leave blank to use
# LLM_DEFAULT_MODEL.
LLM_PLANNING_MODEL=gemma4:26b

# Coding stages 4 (run_aider.py) and 5 (fix_imports.py) share this key.
# Should be coder-tuned. Leave blank to use LLM_DEFAULT_MODEL.
#LLM_AIDER_MODEL=

# Debug + analysis workers (all LocalLLMDebug/*_local.ps1 and
# LocalLLMAnalysis/*_local.ps1). Leave blank to use LLM_DEFAULT_MODEL.
#LLM_MODEL=

# ── Thinking mode (reasoning-model support for planning) ──
# gemma4:26b and similar reasoning models emit reasoning in message.thinking
# separately from message.content. LLM_THINK=true puts the model in thinking
# mode on /api/chat; LLM_SAVE_THINKING=true writes reasoning to
# <stage-output>.thinking.md sidecars for audit/debug.
LLM_THINK=true
LLM_SAVE_THINKING=true

# ── Context / token / timeout budgets (per role) ──
# Planning needs a large output budget: thinking + content both come out of
# num_predict. 65536 leaves room for several-thousand-token reasoning plus
# the final structured output.
LLM_PLANNING_NUM_CTX=98304
LLM_PLANNING_MAX_TOKENS=65536
# Thinking on a 26B model is slow -- 16k tokens can take 5-15 minutes. The
# debug/analysis default (LLM_TIMEOUT=300) is too tight for planning.
LLM_PLANNING_TIMEOUT=1200

# Aider / Stage 4. Larger context helps with multi-file edits.
LLM_AIDER_NUM_CTX=40960

# Debug + analysis. When LLM_NUM_CTX > 0, Invoke-LocalLLM uses /api/chat
# with options.num_ctx so the model gets the full window on every call.
# When 0 or unset, it falls back to /v1/chat/completions.
LLM_NUM_CTX=32768

# LocalLLMAnalysis uses a larger window -- arch synthesis + pass 2 read
# many per-file docs at once. Analysis scripts promote this value into
# LLM_NUM_CTX after loading config.
LLM_ANALYSIS_NUM_CTX=49152

LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=800
# 900s (was 300) because thinking-MoE models like qwen3.6:35b-a3b burn
# 2-3 minutes in the reasoning pass alone; analyse/fix calls then need
# another 3-5 minutes to emit 8-16k tokens of output. Drop back to 300
# when switching to a non-thinking coder via LLM_MODEL override.
LLM_TIMEOUT=900

# ── bughunt_iterative token budgets (thinking-model friendly) ──
# The analyse/fix calls must fit BOTH the reasoning chain AND the output.
# Defaults (900 / 4000) are tuned for non-thinking coders; thinking-MoE
# models like qwen3.6:35b-a3b exhaust the 900-token analyse budget inside
# reasoning alone and never emit content. Raise these when using a
# thinking model; drop back to defaults when LLM_MODEL is a coder.
BUGHUNT_ANALYSE_TOKENS=8000
BUGHUNT_FIX_TOKENS=16000

# ── Debug ← Analysis integration paths ──
#
# When the Analysis pipeline has been run, its outputs can be fed into the
# Debug pipeline for better context. These paths are relative to the current
# working directory (i.e. the repo root from which the script is invoked),
# unless absolute.
#
# Arch_Analysis_Pipeline.py writes outputs to "architecture/" during a run and
# renames that folder to "N. <subsection>" on completion. Update
# ARCHITECTURE_DIR to point at the renamed folder if you want Debug scripts to
# consume Analysis outputs after a full Analysis run. Leave empty (or comment
# out) to disable the integration entirely.
#
# Debug scripts that consume these:
#   bughunt_local.ps1      -- reads <ARCHITECTURE_DIR>/xref_index.md
#   dataflow_local.ps1     -- reads <ARCHITECTURE_DIR>/architecture.md (synth pass)
#   interfaces_local.ps1   -- reads <SERENA_CONTEXT_DIR>/<rel>.serena_context.txt per file
#
# All integrations gracefully skip when the expected file is missing.
ARCHITECTURE_DIR=architecture
SERENA_CONTEXT_DIR=architecture/.serena_contextt

# ── Codebase ──
PRESET=python
CODEBASE_DESC="nmon -- a Python terminal system/GPU monitor. Collects GPU metrics via NVML and nvidia-smi, stores samples in SQLite, and renders a live TUI (Rich-based) with a dashboard, history view, and configurable widgets. Stack: Python 3.10+, rich, pynvml, readchar, TOML config, pytest test suite."

# ── File handling ──
MAX_FILE_LINES=800
SKIP_TRIVIAL=1
MIN_TRIVIAL_LINES=10
CHUNK_THRESHOLD=400

# ── Preset overrides ──
# Match Python source and project config; exclude generated/cache dirs.
INCLUDE_EXT_REGEX=\.(py|toml)$
EXCLUDE_DIRS_REGEX=[/\\](\.git|architecture|__pycache__|\.egg-info|\.tox|\.venv|venv|dist|build|\.pytest_cache|\.mypy_cache)([/\\]|$)

#Subsections begin
src/phonebook
# Python package: FastAPI app, CRUD, HTMX routes, templates
#Subsections end
