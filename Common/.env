# .env -- Shared Local LLM pipeline configuration
#
# Location: nmonLocalLLM/Common/.env
# Consumed by:
#   - LocalLLMCoding/Arch_Coding_Pipeline.ps1  (when -Local)
#   - LocalLLMCoding/run_aider.py                (when --local)
#   - LocalLLMDebug/*_local.ps1                  (analysis scripts)

# ── Ollama server endpoint ──
# One-line override: uncomment LLM_ENDPOINT to use a full URL.
# Otherwise LLM_HOST + LLM_PORT are composed into http://HOST:PORT.
#LLM_ENDPOINT=http://192.168.1.126:11434
LLM_HOST=192.168.1.126
LLM_PORT=11434

# ── Models ──

# Planning model -- used by Arch_Coding_Pipeline.ps1 for stages 2a/2b/3a/3b
# when -Local is set. Should be strong at structured output + long-context
# reasoning (architecture sections, numbered step lists).
LLM_PLANNING_MODEL=gemma4:26b
LLM_PLANNING_NUM_CTX=98304

# Thinking-model support for the planning pipeline. gemma4:26b (and other
# reasoning models) emit reasoning in message.thinking separately from
# message.content. When LLM_THINK=true, Invoke-LocalLLM sends think:true on
# /api/chat so the model is explicitly in thinking mode; when
# LLM_SAVE_THINKING=true, the Arch_Coding_Pipeline pipeline writes reasoning
# to <stage-output>.thinking.md sidecars for audit/debug.
LLM_THINK=true
LLM_SAVE_THINKING=true

# Planning stages need a much larger output budget than debug calls because
# thinking + content both come out of num_predict. 16384 leaves room for
# several-thousand-token reasoning plus the final structured output.
LLM_PLANNING_MAX_TOKENS=65536

# Thinking on a 26B model is slow -- generating 16k tokens can take 5-15
# minutes. Keep LLM_TIMEOUT at 300 for the debug pipeline, but use a longer
# window for planning so the HTTP call doesn't abort mid-generation.
LLM_PLANNING_TIMEOUT=1200

# Aider model -- used by run_aider.py when --local is set. Should be
# coder-tuned; larger context helps with multi-file edits.
LLM_AIDER_MODEL=qwen3-coder:30b
LLM_AIDER_NUM_CTX=40960

# Model used by fix_imports.py when invoking aider to resolve cross-file
# import errors. Kept separate from LLM_AIDER_MODEL so the import-repair
# pass can use a stronger coder model without changing the main aider flow.
LLM_FIX_IMPORTS_MODEL=qwen3-coder:30b

# Analysis / Debug model -- used by LocalLLMDebug/*_local.ps1 (dataflow,
# interfaces, testgap, bughunt, bughunt_iterative) and by
# LocalLLMAnalysis/*.ps1 (archgen, arch_overview, archpass2).
#
# When LLM_NUM_CTX > 0, Invoke-LocalLLM routes via native /api/chat with
# options.num_ctx so the model gets the full window on every call. When 0
# (or unset), it falls back to the legacy /v1/chat/completions path.
LLM_MODEL=qwen3-coder:30b
LLM_NUM_CTX=32768

# LocalLLMAnalysis uses a larger window -- arch synthesis and pass 2 read
# many per-file docs at once. Analysis scripts promote this value into
# LLM_NUM_CTX after loading config, so Invoke-LocalLLM picks it up via the
# standard auto-read path.
LLM_ANALYSIS_NUM_CTX=49152

# High-context variant: three scripts (bughunt_iterative, interfaces synth,
# testgap synth) read LLM_MODEL_HIGH_CTX first and fall back to LLM_MODEL.
# With qwen3-coder:30b everywhere + per-request num_ctx, both point at the
# same model — this key is kept for backward-compat with the script logic.
LLM_MODEL_HIGH_CTX=qwen3-coder:30b

LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=800
# bughunt_iterative fix calls on qwen2.5-coder:32b regularly need 150-250s; 120s was too tight
LLM_TIMEOUT=300

# ── Debug ← Analysis integration paths ──
#
# When the Analysis pipeline has been run, its outputs can be fed into the
# Debug pipeline for better context. These paths are relative to the current
# working directory (i.e. the repo root from which the script is invoked),
# unless absolute.
#
# Arch_Analysis_Pipeline.py writes outputs to "architecture/" during a run and
# renames that folder to "N. <subsection>" on completion. Update
# ARCHITECTURE_DIR to point at the renamed folder if you want Debug scripts to
# consume Analysis outputs after a full Analysis run. Leave empty (or comment
# out) to disable the integration entirely.
#
# Debug scripts that consume these:
#   bughunt_local.ps1      -- reads <ARCHITECTURE_DIR>/xref_index.md
#   dataflow_local.ps1     -- reads <ARCHITECTURE_DIR>/architecture.md (synth pass)
#   interfaces_local.ps1   -- reads <SERENA_CONTEXT_DIR>/<rel>.serena_context.txt per file
#
# All integrations gracefully skip when the expected file is missing.
ARCHITECTURE_DIR=architecture
SERENA_CONTEXT_DIR=architecture/.serena_contextt

# ── Codebase ──
PRESET=python
CODEBASE_DESC="nmon -- a Python terminal system/GPU monitor. Collects GPU metrics via NVML and nvidia-smi, stores samples in SQLite, and renders a live TUI (Rich-based) with a dashboard, history view, and configurable widgets. Stack: Python 3.10+, rich, pynvml, readchar, TOML config, pytest test suite."

# ── File handling ──
MAX_FILE_LINES=800
SKIP_TRIVIAL=1
MIN_TRIVIAL_LINES=10
CHUNK_THRESHOLD=400

# ── Preset overrides ──
# Match Python source and project config; exclude generated/cache dirs.
INCLUDE_EXT_REGEX=\.(py|toml)$
EXCLUDE_DIRS_REGEX=[/\\](\.git|architecture|__pycache__|\.egg-info|\.tox|\.venv|venv|dist|build|\.pytest_cache|\.mypy_cache)([/\\]|$)

#Subsections begin
src/nmon2
# Python package: models, config, storage, collector, PyQt6 UI tabs
#Subsections end
