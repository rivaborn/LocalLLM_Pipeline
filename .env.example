# Template for .env — copy to .env (which is gitignored) and set values.
#
#   cp .env.example .env
#   # then edit .env
#
# Real env vars set in your shell take precedence over .env.

# Common/_pipeline/claude.py — per-account CLAUDE_CONFIG_DIR overrides.
# If unset, defaults are ~/.claudemain (claude1) and ~/.claudealt (claude2).
# `~` is expanded; you can also use a full path.
CLAUDE1_CONFIG_DIR=
CLAUDE2_CONFIG_DIR=
